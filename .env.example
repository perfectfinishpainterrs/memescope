# ═══════════════════════════════════════════
# MEMESCOPE — Environment Variables
# Copy to .env.local and fill in your keys
# ═══════════════════════════════════════════

# ── Supabase ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Blockchain ─────────────────────────
# Helius — https://dev.helius.xyz
# Used for: RPC, token data, DAS API, parsed transactions
HELIUS_API_KEY=
HELIUS_RPC_URL=

# Moralis — https://moralis.io (EVM chains)
MORALIS_API_KEY=

# Birdeye — https://birdeye.so (Solana token data)
BIRDEYE_API_KEY=

# ── AI ─────────────────────────────────
# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Grok / xAI — https://console.x.ai
# Primary for X/Twitter search (has native X access)
GROK_API_KEY=

# ── Twitter/X ──────────────────────────
# X API — https://developer.x.com (fallback, optional if using Grok)
X_BEARER_TOKEN=

# ── App ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MEMESCOPE

# ── Cron ───────────────────────────────
CRON_SECRET=

# ── Optional ───────────────────────────
# GoPlus — https://gopluslabs.io (scam detection)
GOPLUS_API_KEY=
