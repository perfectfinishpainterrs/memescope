# ═══════════════════════════════════════════
# MEMESCOPE — Environment Variables
# Copy to .env.local and fill in your keys
# ═══════════════════════════════════════════

# ── Database (Supabase) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Solana ───────────────────────────────
# Helius — https://dev.helius.xyz
# Used for: RPC, token data, DAS API, parsed transactions
HELIUS_API_KEY=your-helius-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── EVM (optional, Phase 8) ─────────────
# Moralis — https://moralis.io
MORALIS_API_KEY=your-moralis-key

# Alchemy (backup RPC)
ALCHEMY_API_KEY=your-alchemy-key

# ── Token Data ───────────────────────────
# DEXScreener — https://docs.dexscreener.com (free, no key needed)
# Birdeye — https://birdeye.so (optional, enhances Solana data)
BIRDEYE_API_KEY=your-birdeye-key

# GeckoTerminal — https://geckoterminal.com (free, no key needed)

# ── Scam Detection ──────────────────────
# GoPlus — https://gopluslabs.io
GOPLUS_API_KEY=your-goplus-key

# ── Twitter/X (Phase 5) ─────────────────
# X API — https://developer.x.com
X_BEARER_TOKEN=your-x-bearer-token

# ── AI Research (Phase 6) ───────────────
# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key

# ── App Config ───────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MEMESCOPE
